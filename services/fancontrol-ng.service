[Unit]
Description=FanControl-NG - Custom Fan Control Service for ODROID-HC4
After=multi-user.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /path/to/your/fancontrol-ng.py  # Replace with the actual path to your Python script
Restart=always
User=root  # Or change to a non-root user if permissions are set up
WorkingDirectory=/path/to/script/directory  # Optional: Set if needed
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
